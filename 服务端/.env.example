# 服务配置
PORT=3000
NODE_ENV=development

# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=trading_system
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# 邮箱 SMTP 配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@qq.com
SMTP_PASS=your_authorization_code
SMTP_FROM_ADDRESS=your_email@qq.com
SMTP_FROM_NAME=交易系统

# 文件上传配置
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=5242880
UPLOAD_BASE_URL=http://localhost:3000

# 验证码配置
CODE_EXPIRE_MINUTES=10
CODE_SEND_INTERVAL_SECONDS=60
