# ===== 服务器 =====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===== MySQL =====
DATABASE_URL="mysql://root:Trading@2026@localhost:3306/trading_db"

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT（mobile 和 admin 分离密钥）=====
JWT_MOBILE_SECRET=your_mobile_jwt_secret_key_here
JWT_ADMIN_SECRET=your_admin_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== 邮件 SMTP =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=寰球汇金交易所

# ===== 短信（国阳云）=====
SMS_API_URL=
SMS_API_KEY=
SMS_TEMPLATE_ID=

# ===== 文件上传 =====
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=5242880

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# ===== Binance Pay（可选）=====
BINANCE_PAY_ENABLED=false
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
